# Master Signal Agent — Environment Variables
# Copy this to .env and fill in your values

# ── TwelveData ─────────────────────────────────────────────────
# Use a SEPARATE TwelveData account (800 credits/day)
# This agent fetches 4 timeframes × 5 pairs = 20 API calls per cycle
# At 5min intervals = 20 calls × 288 cycles/day = 5,760 calls/day
# ⚠️  FREE tier = 800/day. Upgrade to Basic ($8/mo = 5,000/day) or use multiple keys
TWELVEDATA_API_KEY_MASTER=your_api_key_here

# ── Discord ────────────────────────────────────────────────────
# Create a new #master-signals channel in your Discord server
# Right-click channel → Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_MASTER_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here

# ── Agent Config ───────────────────────────────────────────────
DEBUG_MODE=true

# ── Timezone (Render env) ──────────────────────────────────────
TZ=UTC

# ── PORT (Render sets this automatically) ─────────────────────
PORT=3000
